#!/usr/bin/env bash
# chromeos — CLI for managing a ChromeOS development device
#
# Usage: chromeos <command> [args...]
#
# Commands:
#   doctor              Check connectivity, devtools, client.py, etc.
#   fix-ssh             Restart sshd after reboot
#   fix-devtools        Re-enable --remote-debugging-port=9222
#   deploy              Deploy/update client.py on Chromebook
#   screenshot [file] [--method egl|gbm|keyboard] [--jpeg|--png] [-q N]  Take screenshot
#   tap X Y             Tap at raw touchscreen coordinates
#   swipe X1 Y1 X2 Y2 [MS]  Swipe gesture (default 200ms)
#   mouse-move X Y      Move virtual mouse to pixel coords (external display)
#   mouse-click [left|right|middle] [X Y]  Click virtual mouse (optionally at X Y)
#   mouse-scroll DELTA  Scroll wheel (positive=up, negative=down)
#   type "text"         Type text via keyboard
#   shortcut mod key    Keyboard shortcut (e.g. chromeos shortcut ctrl t)
#   info                Device info (touch_max, keyboard layout)
#   remote-desktop [port]  Start remote desktop web server (default port 8765)
#   targets             List Chrome DevTools targets (pages/tabs)
#   axtree [target]     Dump accessibility tree for a target
#   find <pat> [opts]   Find elements by name (--role ROLE, --target N)
#   click <pat> [opts]  Click element by name (--role ROLE, --target N)
#   desktop-tree [--depth N]  Full desktop accessibility tree (system UI)
#   desktop-find <pat> [--role R]  Find desktop elements by name
#   desktop-click <pat> [--role R] Click desktop element via doDefault()
#   desktop-action <pat> <action> [--value V] [--role R] [--nth N]  Perform action on desktop element
#   deploy-ext <dir> [--name NAME] [--reload [EXT_ID]]  Deploy extension to Chromebook
#   install-apk <file> [--keep]  Install Android APK on Chromebook
#   shell               Interactive SSH session
#   help                Show this help

set -euo pipefail

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SSH_HOST="${CHROMEBOOK_HOST:-chromeroot}"
CLIENT_PATH="${CHROMEOS_CLIENT_PATH:-/mnt/stateful_partition/c2/client.py}"
REMOTE_PATH_SETUP="export PATH=/bin:/usr/bin:/usr/local/bin:/usr/sbin:/sbin:\$PATH"
SSH_OPTS=(-o ControlMaster=auto -o "ControlPath=/tmp/chromeos-ssh-%C" -o ControlPersist=300)

# Send a JSON command to client.py on the Chromebook
send_cmd() {
    local json="$1"
    echo "$json" | ssh "${SSH_OPTS[@]}" "$SSH_HOST" \
        "$REMOTE_PATH_SETUP; LD_LIBRARY_PATH=/usr/local/lib64 python3 $CLIENT_PATH" 2>/dev/null
}

# Ensure client files are deployed (skip if unchanged)
ensure_client() {
    local client_dir
    client_dir=$(dirname "$CLIENT_PATH")

    # Hash local files to detect changes
    local hash_file="/tmp/chromeos-deploy-hash"
    local current_hash
    current_hash=$(cat "$REPO_DIR/client.py" "$REPO_DIR/drm_screenshot.py" "$REPO_DIR/cdp.py" \
        2>/dev/null | shasum -a 256 | cut -c1-16)
    if [[ -f "$hash_file" ]] && [[ "$(cat "$hash_file" 2>/dev/null)" == "$current_hash" ]]; then
        return 0
    fi

    ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; mkdir -p $client_dir" 2>/dev/null
    scp -q "${SSH_OPTS[@]}" "$REPO_DIR/client.py" "$REPO_DIR/drm_screenshot.py" "$REPO_DIR/cdp.py" "$SSH_HOST:$client_dir/"
    echo "$current_hash" > "$hash_file"
}

cmd_doctor() {
    exec "$REPO_DIR/scripts/doctor.sh" "$@"
}

cmd_fix_ssh() {
    exec "$REPO_DIR/scripts/fix-ssh.sh" "$@"
}

cmd_fix_devtools() {
    exec "$REPO_DIR/scripts/fix-devtools.sh" "$@"
}

cmd_deploy() {
    exec "$REPO_DIR/scripts/deploy-client.sh" "$@"
}

cmd_screenshot() {
    local method="" output="" format="" quality=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --method=*) method="${1#--method=}"; shift ;;
            --method) method="$2"; shift 2 ;;
            --format=*) format="${1#--format=}"; shift ;;
            --format) format="$2"; shift 2 ;;
            --quality=*) quality="${1#--quality=}"; shift ;;
            --quality|-q) quality="$2"; shift 2 ;;
            --png) format="png"; shift ;;
            --jpeg|--jpg) format="jpeg"; shift ;;
            *) output="$1"; shift ;;
        esac
    done

    # Infer format from extension, default to jpeg
    if [[ -z "$format" ]]; then
        case "$output" in
            *.png) format="png" ;;
            *)     format="jpeg" ;;
        esac
    fi
    if [[ -z "$output" ]]; then
        local ext="png"; [[ "$format" == "jpeg" ]] && ext="jpg"
        output="/tmp/chromebook-screenshot.$ext"
    fi

    ensure_client

    # Keyboard method must go through client.py
    if [[ "$method" == "keyboard" ]]; then
        _screenshot_json "$output" "$method" "$format"
        return
    fi

    # Direct binary transfer: drm_screenshot.py --stdout [--jpeg] > file
    local remote_dir
    remote_dir=$(dirname "$CLIENT_PATH")
    local remote_args="--stdout"
    if [[ "$format" == "jpeg" ]]; then
        remote_args="$remote_args --jpeg"
        [[ -n "$quality" ]] && remote_args="$remote_args -q $quality"
    fi
    [[ -n "$method" ]] && remote_args="$remote_args --method $method"

    if ssh "${SSH_OPTS[@]}" "$SSH_HOST" \
        "$REMOTE_PATH_SETUP; LD_LIBRARY_PATH=/usr/local/lib64 python3 $remote_dir/drm_screenshot.py $remote_args" \
        > "$output" 2>/dev/null && [[ -s "$output" ]]; then
        echo "$output ($format)"
    else
        rm -f "$output"
        _screenshot_json "$output" "$method" "$format"
    fi
}

# Fallback: screenshot via client.py JSON/base64 path
_screenshot_json() {
    local output="$1" method="$2" format="$3"
    local cmd_json='{"cmd":"screenshot"'
    [[ -n "$method" ]] && cmd_json="$cmd_json,\"method\":\"$method\""
    [[ "$format" == "jpeg" ]] && cmd_json="$cmd_json,\"format\":\"jpeg\""
    cmd_json="$cmd_json}"
    local response
    response=$(send_cmd "$cmd_json")

    if echo "$response" | python3 -c "import sys,json; r=json.load(sys.stdin); sys.exit(0 if 'image' in r else 1)" 2>/dev/null; then
        local used_method
        used_method=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('method',''))" 2>/dev/null)
        echo "$response" | python3 -c "
import sys, json, base64
r = json.load(sys.stdin)
sys.stdout.buffer.write(base64.b64decode(r['image']))
" > "$output"
        echo "$output${used_method:+ ($used_method)}"
    else
        local error
        error=$(echo "$response" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','Unknown error'))" 2>/dev/null || echo "No response from client")
        echo "Error: $error" >&2
        exit 1
    fi
}

cmd_tap() {
    local x="${1:?Usage: chromeos tap X Y}"
    local y="${2:?Usage: chromeos tap X Y}"
    ensure_client
    send_cmd "{\"cmd\":\"tap\",\"x\":$x,\"y\":$y}"
}

cmd_swipe() {
    local x1="${1:?Usage: chromeos swipe X1 Y1 X2 Y2 [DURATION_MS]}"
    local y1="${2:?Usage: chromeos swipe X1 Y1 X2 Y2 [DURATION_MS]}"
    local x2="${3:?Usage: chromeos swipe X1 Y1 X2 Y2 [DURATION_MS]}"
    local y2="${4:?Usage: chromeos swipe X1 Y1 X2 Y2 [DURATION_MS]}"
    local duration="${5:-200}"
    ensure_client
    send_cmd "{\"cmd\":\"swipe\",\"x1\":$x1,\"y1\":$y1,\"x2\":$x2,\"y2\":$y2,\"duration_ms\":$duration}"
}

cmd_mouse_move() {
    local x="${1:?Usage: chromeos mouse-move X Y}"
    local y="${2:?Usage: chromeos mouse-move X Y}"
    ensure_client
    send_cmd "{\"cmd\":\"mouse_move\",\"x\":$x,\"y\":$y}"
}

cmd_mouse_click() {
    local button="${1:-left}"
    local x="${2:-}"
    local y="${3:-}"
    ensure_client
    if [[ -n "$x" && -n "$y" ]]; then
        send_cmd "{\"cmd\":\"mouse_click\",\"button\":\"$button\",\"x\":$x,\"y\":$y}"
    else
        send_cmd "{\"cmd\":\"mouse_click\",\"button\":\"$button\"}"
    fi
}

cmd_mouse_scroll() {
    local delta="${1:?Usage: chromeos mouse-scroll DELTA}"
    ensure_client
    send_cmd "{\"cmd\":\"mouse_scroll\",\"delta\":$delta}"
}

cmd_type() {
    local text="${1:?Usage: chromeos type \"text\"}"
    ensure_client
    local json
    json=$(python3 -c "import json; print(json.dumps({'cmd':'type','text':$(python3 -c "import json,sys; print(json.dumps(sys.argv[1]))" "$text")}))")
    send_cmd "$json"
}

cmd_shortcut() {
    if [ $# -lt 1 ]; then
        echo "Usage: chromeos shortcut [modifier...] key" >&2
        echo "  e.g. chromeos shortcut ctrl t" >&2
        echo "  e.g. chromeos shortcut ctrl shift n" >&2
        exit 1
    fi
    ensure_client

    # Last arg is the key, everything before is modifiers
    local args=("$@")
    local key="${args[${#args[@]}-1]}"
    local mods=()
    for ((i=0; i<${#args[@]}-1; i++)); do
        mods+=("\"${args[$i]}\"")
    done

    local mods_json
    mods_json=$(IFS=,; echo "[${mods[*]}]")
    send_cmd "{\"cmd\":\"shortcut\",\"modifiers\":$mods_json,\"key\":\"$key\"}"
}

cmd_info() {
    ensure_client
    send_cmd '{"cmd":"info"}'
}

cmd_targets() {
    ensure_client
    local response
    response=$(send_cmd '{"cmd":"targets"}')
    if echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
for t in r['targets']:
    print(f\"  {t['index']}: {t['title']}\")
    print(f\"     {t['url']}\")
" 2>&1; then
        :
    else
        echo "Error: Failed to list targets" >&2
        exit 1
    fi
}

cmd_axtree() {
    local target=0 depth=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --depth) depth="$2"; shift 2 ;;
            *) target="$1"; shift ;;
        esac
    done
    ensure_client
    local json_cmd="{\"cmd\":\"axtree\",\"target\":$target"
    [ -n "$depth" ] && json_cmd="$json_cmd,\"depth\":$depth"
    json_cmd="$json_cmd}"
    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
print(r['tree'])
print(f\"---\n{r['node_count']} nodes\", file=sys.stderr)
"
}

cmd_find() {
    if [ $# -lt 1 ]; then
        echo "Usage: chromeos find <pattern> [--role ROLE] [--target N]" >&2
        exit 1
    fi
    local pattern="$1"
    shift
    local role="" target=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            --target) target="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client

    local json_cmd
    json_cmd=$(python3 -c "
import json, sys
cmd = {'cmd': 'find', 'pattern': sys.argv[1], 'target': int(sys.argv[2])}
if sys.argv[3]: cmd['role'] = sys.argv[3]
print(json.dumps(cmd))
" "$pattern" "$target" "$role")

    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
for m in r['matches']:
    parts = [f\"[{m['role']}]\", f\"\\\"{m['name']}\\\"\"]
    b = m.get('bounds')
    if b:
        parts.append(f\"at ({b['center_x']:.0f},{b['center_y']:.0f}) {b['width']:.0f}x{b['height']:.0f}\")
    print(' '.join(parts))
print(f\"---\n{r['count']} matches\", file=sys.stderr)
"
}

cmd_click() {
    if [ $# -lt 1 ]; then
        echo "Usage: chromeos click <pattern> [--role ROLE] [--target N]" >&2
        exit 1
    fi
    local pattern="$1"
    shift
    local role="" target=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            --target) target="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client

    local json_cmd
    json_cmd=$(python3 -c "
import json, sys
cmd = {'cmd': 'click', 'pattern': sys.argv[1], 'target': int(sys.argv[2])}
if sys.argv[3]: cmd['role'] = sys.argv[3]
print(json.dumps(cmd))
" "$pattern" "$target" "$role")

    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
c = r['clicked']
print(f\"Clicked [{c['role']}] \\\"{c['name']}\\\" at ({c['x']:.0f},{c['y']:.0f})\")
"
}

cmd_desktop_tree() {
    local depth=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --depth) depth="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client
    local json_cmd='{"cmd":"desktop_tree"'
    [ -n "$depth" ] && json_cmd="$json_cmd,\"depth\":$depth"
    json_cmd="$json_cmd}"
    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
def render(node, depth=0):
    role = node.get('role', '')
    name = node.get('name', '')
    if not role and not name:
        for c in node.get('children', []):
            render(c, depth)
        return
    parts = []
    if role:
        parts.append(f'[{role}]')
    if name:
        parts.append(f'\"{name}\"')
    st = node.get('state', {})
    for k in st:
        parts.append(f'({k})')
    if parts:
        print('  ' * depth + ' '.join(parts))
    for c in node.get('children', []):
        render(c, depth + 1)
render(r['tree'])
"
}

cmd_desktop_find() {
    if [ $# -lt 1 ]; then
        echo "Usage: chromeos desktop-find <pattern> [--role ROLE]" >&2
        exit 1
    fi
    local pattern="$1"
    shift
    local role=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client

    local json_cmd
    json_cmd=$(python3 -c "
import json, sys
cmd = {'cmd': 'desktop_find', 'pattern': sys.argv[1]}
if sys.argv[2]: cmd['role'] = sys.argv[2]
print(json.dumps(cmd))
" "$pattern" "$role")

    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
for m in r['matches']:
    parts = [f\"[{m['role']}]\", f\"\\\"{m['name']}\\\"\"]
    loc = m.get('location')
    if loc:
        parts.append(f\"at ({loc['center_x']:.0f},{loc['center_y']:.0f}) {loc['width']:.0f}x{loc['height']:.0f}\")
    if 'valueForRange' in m:
        vr = f\"value={m['valueForRange']}\"
        if 'minValueForRange' in m:
            vr += f\" min={m['minValueForRange']}\"
        if 'maxValueForRange' in m:
            vr += f\" max={m['maxValueForRange']}\"
        parts.append(vr)
    if 'checked' in m:
        parts.append(f\"checked={m['checked']}\")
    if 'value' in m:
        parts.append(f\"value=\\\"{m['value']}\\\"\")
    print(' '.join(parts))
print(f\"---\n{r['count']} matches\", file=sys.stderr)
"
}

cmd_desktop_click() {
    if [ $# -lt 1 ]; then
        echo "Usage: chromeos desktop-click <pattern> [--role ROLE]" >&2
        exit 1
    fi
    local pattern="$1"
    shift
    local role=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client

    local json_cmd
    json_cmd=$(python3 -c "
import json, sys
cmd = {'cmd': 'desktop_click', 'pattern': sys.argv[1]}
if sys.argv[2]: cmd['role'] = sys.argv[2]
print(json.dumps(cmd))
" "$pattern" "$role")

    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
c = r['clicked']
loc = c.get('location')
pos = f\" at ({loc['x']:.0f},{loc['y']:.0f})\" if loc else ''
print(f\"Clicked [{c['role']}] \\\"{c['name']}\\\"{pos}\")
"
}

cmd_desktop_action() {
    if [ $# -lt 2 ]; then
        echo "Usage: chromeos desktop-action <pattern> <action> [--value V] [--role R] [--nth N]" >&2
        echo "  Actions: doDefault, focus, increment, decrement, setValue," >&2
        echo "           showContextMenu, scrollForward, scrollBackward, longClick" >&2
        exit 1
    fi
    local pattern="$1" action="$2"
    shift 2
    local role="" value="" nth=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            --value) value="$2"; shift 2 ;;
            --nth) nth="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done
    ensure_client

    local json_cmd
    json_cmd=$(python3 -c "
import json, sys
cmd = {'cmd': 'desktop_action', 'pattern': sys.argv[1], 'action': sys.argv[2]}
if sys.argv[3]: cmd['role'] = sys.argv[3]
if sys.argv[4]: cmd['value'] = sys.argv[4]
if sys.argv[5]: cmd['nth'] = int(sys.argv[5])
print(json.dumps(cmd))
" "$pattern" "$action" "$role" "$value" "$nth")

    local response
    response=$(send_cmd "$json_cmd")
    echo "$response" | python3 -c "
import sys, json
r = json.load(sys.stdin)
if 'error' in r:
    print(r['error'], file=sys.stderr)
    sys.exit(1)
res = r['result']
loc = res.get('location')
pos = f\" at ({loc['x']:.0f},{loc['y']:.0f})\" if loc else ''
parts = [f\"[{res['role']}] \\\"{res['name']}\\\"{pos}\", f\"action={res['action']}\"]
if 'valueForRange' in res:
    parts.append(f\"value={res['valueForRange']}\")
    if 'minValueForRange' in res:
        parts.append(f\"min={res['minValueForRange']}\")
    if 'maxValueForRange' in res:
        parts.append(f\"max={res['maxValueForRange']}\")
if 'checked' in res:
    parts.append(f\"checked={res['checked']}\")
if 'value' in res:
    parts.append(f\"value=\\\"{res['value']}\\\"\")
print(' '.join(parts))
"
}

cmd_deploy_ext() {
    local dir="" name="" reload="" ext_id=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name=*) name="${1#--name=}"; shift ;;
            --name) name="$2"; shift 2 ;;
            --reload=*) reload=1; ext_id="${1#--reload=}"; shift ;;
            --reload) reload=1; shift
                      # Next arg is ext_id if it doesn't start with --
                      if [[ $# -gt 0 && "$1" != --* ]]; then
                          ext_id="$1"; shift
                      fi ;;
            *) dir="$1"; shift ;;
        esac
    done

    if [[ -z "$dir" ]]; then
        echo "Usage: chromeos deploy-ext <dir> [--name NAME] [--reload [EXT_ID]]" >&2
        exit 1
    fi
    if [[ ! -d "$dir" ]]; then
        echo "Error: $dir is not a directory" >&2
        exit 1
    fi

    [[ -z "$name" ]] && name=$(basename "$dir")
    local dest="/home/chronos/user/MyFiles/Downloads/$name"

    echo "Deploying extension to $SSH_HOST:$dest/"
    ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; mkdir -p '$dest'" 2>/dev/null
    # rsync may not be available on ChromeOS — fall back to scp
    if ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; which rsync" &>/dev/null; then
        rsync -av --delete \
            --exclude='.git' \
            --exclude='node_modules' \
            --rsync-path="$REMOTE_PATH_SETUP; rsync" \
            -e "ssh ${SSH_OPTS[*]}" \
            "$dir/" "$SSH_HOST:$dest/"
    else
        # Clean dest and scp files (excluding .git and node_modules)
        ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; rm -rf '$dest'/*" 2>/dev/null
        scp -r "${SSH_OPTS[@]}" "$dir/"* "$SSH_HOST:$dest/" 2>/dev/null
    fi

    if [[ -n "$reload" ]]; then
        local cdp_port="${CDP_PORT:-9222}"
        if ! nc -z localhost "$cdp_port" 2>/dev/null; then
            echo "CDP port $cdp_port not available — skipping reload (set up SSH tunnel: ssh -NL 9222:127.0.0.1:9222 chromeroot)"
        else
            echo "Reloading extension via CDP..."
            python3 -c "
import json, urllib.request, sys
try:
    import websocket
except ImportError:
    print('websocket-client not installed (pip install websocket-client), skipping reload')
    sys.exit(0)
targets = json.loads(urllib.request.urlopen('http://localhost:$cdp_port/json').read())
ext_id = '$ext_id'
reloaded = 0
for t in targets:
    if t.get('type') != 'service_worker':
        continue
    if ext_id and ext_id not in t.get('url', ''):
        continue
    ws = websocket.create_connection(t['webSocketDebuggerUrl'])
    ws.send(json.dumps({'id': 1, 'method': 'Runtime.evaluate', 'params': {'expression': 'chrome.runtime.reload()'}}))
    ws.close()
    reloaded += 1
if reloaded:
    print(f'Reloaded {reloaded} extension(s)')
else:
    print('No matching service worker found — extension may need manual reload at chrome://extensions')
" 2>/dev/null || echo "CDP reload failed, manual reload may be needed"
        fi
    fi

    echo "Done! Extension deployed to $dest/"
}

cmd_install_apk() {
    local apk="" keep=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --keep) keep=1; shift ;;
            *) apk="$1"; shift ;;
        esac
    done

    if [[ -z "$apk" ]]; then
        echo "Usage: chromeos install-apk <file.apk> [--keep]" >&2
        exit 1
    fi
    if [[ ! -f "$apk" ]]; then
        echo "Error: $apk not found" >&2
        exit 1
    fi

    local filename
    filename=$(basename "$apk")
    local dest="/home/chronos/user/MyFiles/Downloads"

    echo "Copying $filename to $SSH_HOST:$dest/"
    scp "${SSH_OPTS[@]}" "$apk" "$SSH_HOST:$dest/$filename"

    echo "Installing APK..."
    # Prefer adb (avoids android-sh SELinux issues)
    if ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; which adb" &>/dev/null; then
        ssh "${SSH_OPTS[@]}" "$SSH_HOST" \
            "$REMOTE_PATH_SETUP; adb install -r -t '$dest/$filename'" 2>&1
        local rc=$?
    elif ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; which android-sh" &>/dev/null; then
        ssh "${SSH_OPTS[@]}" "$SSH_HOST" \
            "$REMOTE_PATH_SETUP; android-sh -c 'pm install -r -t /sdcard/Download/$filename'" 2>&1
        local rc=$?
    else
        echo "Neither adb nor android-sh found. APK copied to $dest/$filename — install from Files app."
        return 0
    fi

    if [[ $rc -eq 0 && -z "$keep" ]]; then
        ssh "${SSH_OPTS[@]}" "$SSH_HOST" "$REMOTE_PATH_SETUP; rm -f '$dest/$filename'" 2>/dev/null
    fi
    if [[ $rc -eq 0 ]]; then
        echo "Done! APK installed."
    else
        echo "Install failed (rc=$rc). APK is at $dest/$filename — try installing from Files app." >&2
        exit 1
    fi
}

cmd_remote_desktop() {
    local port="${1:-8765}"
    exec python3 "$REPO_DIR/web/server.py" "$port"
}

cmd_shell() {
    exec ssh "${SSH_OPTS[@]}" "$SSH_HOST"
}

cmd_help() {
    sed -En '2,/^$/s/^# ?//p' "$0"
}

# --- Subcommand dispatch ---
cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
    doctor)       cmd_doctor "$@" ;;
    fix-ssh)      cmd_fix_ssh "$@" ;;
    fix-devtools) cmd_fix_devtools "$@" ;;
    deploy)       cmd_deploy "$@" ;;
    screenshot)   cmd_screenshot "$@" ;;
    tap)          cmd_tap "$@" ;;
    swipe)        cmd_swipe "$@" ;;
    mouse-move)   cmd_mouse_move "$@" ;;
    mouse-click)  cmd_mouse_click "$@" ;;
    mouse-scroll) cmd_mouse_scroll "$@" ;;
    type)         cmd_type "$@" ;;
    shortcut)     cmd_shortcut "$@" ;;
    info)         cmd_info "$@" ;;
    targets)      cmd_targets "$@" ;;
    axtree)       cmd_axtree "$@" ;;
    find)         cmd_find "$@" ;;
    click)        cmd_click "$@" ;;
    desktop-tree) cmd_desktop_tree "$@" ;;
    desktop-find) cmd_desktop_find "$@" ;;
    desktop-click) cmd_desktop_click "$@" ;;
    desktop-action) cmd_desktop_action "$@" ;;
    deploy-ext)   cmd_deploy_ext "$@" ;;
    install-apk)  cmd_install_apk "$@" ;;
    remote-desktop) cmd_remote_desktop "$@" ;;
    shell)        cmd_shell "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $cmd" >&2
        echo "Run 'chromeos help' for usage." >&2
        exit 1
        ;;
esac
